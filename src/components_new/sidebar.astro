---
import pagesText from '../text_files/pages.txt?raw';

const pages = pagesText
    .trim()
    .split('\n')
    .map((page: string) => page.trim())
    .filter(Boolean);

const toHref = (page: string) => `/delana/${page.toLowerCase().replace(/\s+/g, '_')}`;
---

<div class="sidebar">
    <div class="pages-links">
        {pages.map((page: string) => (
            <p><a href={toHref(page)}>{page}</a></p>
        ))}
    </div>
    <div class="footnote">
        <p>this site is 
            <a href="https://github.com/astrophysics108/delana">
            open source!
            </a>
        </p>
    </div>
</div>

<style>
    .sidebar {
        background-color: #1b053f;
        width:15em;
        position:fixed;
        height: 100vh;
        top: 0;
        left:0;
        overflow: hidden;
        text-align: left;
        padding: 1em;
    }

    .sidebar :global(p) {
        font-family: "JetBrains Mono", monospace;
        color:#fdedff;
    }

    .sidebar :global(.footnote) {
        position:absolute;
        bottom:0;
        margin-bottom:10%;
        font-size:75%;
    }

    .sidebar :global(a) {
        font-family: "JetBrains Mono", monospace;
        color:#ecc865;
    }

    .sidebar :global(a:hover) {
        font-family: "JetBrains Mono", monospace;
        color:#fceabb;
    }
</style>

