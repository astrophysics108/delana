<html>
    <div class="sidebar">
        <div class="footnote">
            <p>this site is 
                <a href="https://github.com/astrophysics108/delana">
                open source!
                </a>
            </p>
        </div>
    </div>
</html>

<style>
    .sidebar {
        background-color: #1b053f;
        width:15em;
        position:fixed;
        height: 100vh;
        top: 0;
        left:0;
        overflow: hidden;
        text-align: left;
        padding: 1em;
    }

    .sidebar :global(p) {
        font-family: "JetBrains Mono", monospace;
        color:#fdedff;
    }

    .sidebar :global(.footnote) {
        position:absolute;
        bottom:0;
        margin-bottom:10%;
        font-size:75%;
    }

    .sidebar :global(a) {
        font-family: "JetBrains Mono", monospace;
        color:#ecc865;
    }

    .sidebar :global(a:hover) {
        font-family: "JetBrains Mono", monospace;
        color:#fceabb;
    }
</style>

<script>
    fetch('src/text_files/pages.txt')
        .then(r => r.text())
        .then(text => {
            const pages = text.trim().split('\n').map(p => p.trim()).filter(p => p);
            const sidebar = document.querySelector('.sidebar');
            const linksContainer = document.createElement('div');
            linksContainer.className = 'pages-links';

            pages.forEach(page => {
                const href = `/delana/${page.toLowerCase().replace(/\s+/g, '_')}`;
                const link = document.createElement('a');
                link.href = href;
                link.textContent = page;
                const p = document.createElement('p');
                p.appendChild(link);
                linksContainer.appendChild(p);
            });
            const footnote = sidebar.querySelector('.footnote');
            sidebar.insertBefore(linksContainer, footnote);
        });
</script>